{
    "scopeName": "source.asm-preview",
    "patterns": [
        {"include": "#Label"},
        {"include": "#Operation"},
        {"include": "#Memory"},
        {"include": "#Register"},
        {"include": "#Data"},
        {"include": "#JumpLabel"}
    ],
    "repository": {
        "JumpLabel": {
            "name": "entity.name.function",
            "match": "\\.?LBB\\d+_\\d:?"
        },
        "Label": {
            "name": "entity.name.label",
            "match": "^(?!.*LBB)\\w+"
        },
        "Operation": {
            "name": "variable.other",
            "match": "^\\s+\\w+\\.?\\w*"
        },
        "Memory": {
            "name": "variable.parameter",
            "begin": "\\[",
            "end": "\\]",
            "patterns": [
                { "include": "#Register" },
                { "include": "#Data" }
            ]
        }, 
        "Data": {
            "name": "storage.type",
            "match": "\\#-?\\d+\\w*|\\$-?\\d+?\\w*"
        },
        "Register": {
            "name": "comment.line",
            "match": "w\\d+|x\\d+|wzr|xzr|sp|lr|fp|\\%\\w+"
        }
    }
}