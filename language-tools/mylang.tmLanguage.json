{
  "scopeName": "source.mylang",
  "patterns": [
    {"include": "#Comment"},
    {"include": "#Statement"},
    {"include": "#Function"}],
  "repository": {
    "Comment": {
      "name": "comment",
      "patterns": [
        { "name": "comment.line.double-slash",
          "match": "//.*$"},
        { "name": "comment.block",
          "begin": "/\\*",
          "end": "\\*/"}]
    },
    "Statement": {
      "patterns": [
        {"include": "#Expression"},
        {"include": "#ControllStatement"},
        {"include": "#BlockStatement"},
        {"include": "#DeclareInitStatement"}
      ]
    },
    "Expression": {
      "name": "expression",
      "patterns": [
        {"include": "#ParensExp"},
        {"include": "#Operator"},
        {"include": "#Litteral"}
      ]
    },
    "ParensExp": {
      "name":"expression.parens-expression",
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        {"include": "#Comment"},
        {"include":"#Expression"}]
    },
    "Operator": {
      "name": "keyword.operator",
      "patterns": [
        {"include": "#ArithmeticOperator"},
        {"include": "#BooleanOperator"}
      ]
    },
    "ArithmeticOperator": {
      "name": "keyword.operator.arithmetic",
      "patterns": [
        { "name": "keyword.operator.arithmetic.addition",
          "match": "\\+" },
        { "name": "keyword.operator.arithmetic.multiplication",
          "match": "\\*" },
        { "name": "keyword.operator.arithmetic.subtraction",
          "match": "\\-"},
        { "name": "keyword.operator.arithmetic.division",
          "match": "\/"}]
    },
    "BooleanOperator": {
      "name": "keyword.operator.boolean",
      "patterns" : [
        { "name": "keyword.operator.boolean.equality",
          "match": "=="},
        { "name": "keyword.operator.boolean.negated-equality",
          "match" : "!="},
        { "name": "keyword.operator.boolean.negation",
          "match" : "!"},
        { "name": "keyword.operator.boolean.less-or-equal",
          "match" : "<="},
        { "name": "keyword.operator.boolean.greater-or-equal",
          "match" : ">="},
        { "name": "keyword.operator.boolean.less-than",
          "match" : "<"},
        { "name": "keyword.operator.boolean.greater-than",
          "match" : ">"},
        { "name": "keyword.operator.boolean.logic.disjunction",
          "match": "or"},
        { "name": "keyword.operator.boolean.logic.conjunction",
          "match": "and"}
      ]
    },
    "Litteral": {
      "name": "constant.litteral",
      "patterns": [
        { "name": "constant.numeric.expression.litteral.double",
          "match": "\\b[1-9][0-9]*\\.[0-9]*\\b"},
        { "name": "constant.numeric.expression.litteral.integer",
          "match": "\\b[1-9][0-9]*\\b"},
        { "name": "constant.language.expression.litteral.boolean",
          "match": "\\b(true|false)\\b"},
        { "name": "string.quoted.double.expression.litteral.string",
          "begin": "\"",
          "end": "\""}]
    },
    "ControllStatement": {
      "name": "keyword.controll.statement",
      "patterns": [
        { "name": "keyword.controll.statement.return",
          "match": "\\breturn\\b"},
        { "name": "keyword.controll.statement.while",
          "match": "\\bwhile\\b"},
        { "name": "keyword.controll.statement.do",
          "match": "\\bdo\\b"},
        {"include": "#IfStatement"}]
    },
    "IfStatement": {
      "patterns": [
        { "name": "keyword.controll.statement.if",
          "match": "\\bif\\b"},
        { "name": "keyword.controll.statement.else",
          "match": "\\belse\\b"}]
    },
    "BlockStatement": {
      "name": "statement.block",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {"include": "#Comment"},
        {"include": "#Statement"}]
    },
    "DeclareInitStatement": {
      "name": "meta.variable.declaration-initialization",
      "patterns": [
        
      ]
    },
    "Function" : {
      "name": ""
    }
  }
}