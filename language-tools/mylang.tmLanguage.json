{
  "scopeName": "source.mylang",
  "patterns": [
    {"include": "#Comment"},
    {"include": "#FunctionDeclaration"},
    {"include": "#Statement"}],
  "repository": {
    "Statement": {
      "patterns": [
        {"include": "#ControllStatement"},
        {"include": "#Expression"},
        {"include": "#StatementBlock"},
        {"include": "#VariableDeclaration"}
      ]
    },
    "StatementBlock": {
      "name": "statement.block",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {"include": "#Comment"},
        {"include": "#Statement"}
      ]
    },
    "Expression": {
      "name": "expression",
      "patterns":[
        {"include": "#ParensExp"},
        {"include": "#Assignment"},
        {"include": "#Operator"},
        {"include": "#FunctionApplication"},
        {"include": "#Litteral"}
      ]
    },
    "ParensExp": {
      "name":"expression.parens-expression",
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        {"include": "#Comment"},
        {"include":"#Expression"}]
    },
    "Operator": {
      "name": "keyword.operator",
      "patterns": [
        {"include": "#AssignmentOperator"},
        {"include": "#IncrementDecrementOperator"},
        {"include": "#ArithmeticOperator"},
        {"include": "#BooleanOperator"}
      ]
    },
    "AssignmentOperator": {
      "name": "keyword.operator.assignment",
      "patterns":[
        { "name": "keyword.operator.assignment.assign",
          "match": "="},
        { "name": "keyword.operator.assignment.addition-assign",
          "match": "\\+="},
        { "name": "keyword.operator.assignment.subtraction-assign",
          "match": "-="},
        { "name": "keyword.operator.assignment.multiplication-assign",
          "match": "\\*="},
        { "name": "keyword.operator.assignment.division-assign",
          "match": "\\/="}
      ]
    },
    "IncrementDecrementOperator": {
      "name": "keyword.operator.increment-decrement",
      "patterns": [
        { "name": "keyword.operator.increment",
          "match": "\\+\\+"},
        { "name": "keyword.operator.decrement",
          "match": "--"}
      ]
    },
    "ArithmeticOperator": {
      "name": "keyword.operator.arithmetic",
      "patterns": [
        { "name": "keyword.operator.arithmetic.addition",
          "match": "\\+" },
        { "name": "keyword.operator.arithmetic.multiplication",
          "match": "\\*" },
        { "name": "keyword.operator.arithmetic.subtraction",
          "match": "\\-"},
        { "name": "keyword.operator.arithmetic.division",
          "match": "\/"}]
    },
    "BooleanOperator": {
      "name": "keyword.operator.boolean",
      "patterns" : [
        {"include": "#Equality"},
        {"include": "#NegatedEquality"},
        {"include": "#Negation"},
        {"include": "#LessThanOrEqual"},
        {"include": "#GreaterThanOrEqual"},
        {"include": "#LessThan"},
        {"include": "#GreaterThan"},
        {"include": "#Disjuntion"},
        {"include": "#Conjunction"}
      ]
    },
    "Equality": {
      "name": "keyword.operator.boolean.equality",
      "match": "=="
    },
    "Negation": {
      "name": "keyword.operator.boolean.negation",
      "match" : "!"
    },
    "NegatedEquality": {
      "name": "keyword.operator.boolean.negated-equality",
      "match" : "!="
    },
    "LessThan": {
      "name": "keyword.operator.boolean.less-than",
      "match" : "<"
    },
    "GreaterThan": {
      "name": "keyword.operator.boolean.greater-than",
      "match" : ">"
    },
    "LessThanOrEqual": {
      "name": "keyword.operator.boolean.less-or-equal",
      "match" : "<="
    },
    "GreaterThanOrEqual": {
      "name": "keyword.operator.boolean.greater-or-equal",
      "match" : ">="
    },
    "Disjuntion": {
      "name": "keyword.operator.boolean.logic.disjunction",
      "match": "\\bor\\b"
    },
    "Conjunction": {
      "name": "keyword.operator.boolean.logic.conjunction",
      "match": "\\band\\b"
    },
    "Litteral": {
      "name": "constant.litteral",
      "patterns": [
        { "name": "constant.numeric.expression.litteral.double",
          "match": "\\b[1-9][0-9]*\\.[0-9]*\\b"},
        { "name": "constant.numeric.expression.litteral.integer",
          "match": "\\b[1-9][0-9]*\\b"},
        { "name": "constant.language.expression.litteral.boolean",
          "match": "\\b(true|false)\\b"},
        { "name": "string.quoted.double.expression.litteral.string",
          "begin": "\"",
          "end": "\""}]
    },
    "FunctionApplication": {
      "name": "meta.function-application",
      "begin": "\\b([a-z]\\w*)\\(",
      "end": "\\)",
      "beginCaptures": {
        "1": {"name": "entity.name.function.function-id"}
      },
      "patterns": [
        {"include": "#Expression"}
      ]
    },
    "ControllStatement": {
      "name": "keyword.controll.statement",
      "patterns": [
        { "name": "keyword.controll.statement.return",
          "match": "\\breturn\\b"},
        { "name": "keyword.controll.statement.while",
          "match": "\\bwhile\\b"},
        { "name": "keyword.controll.statement.do",
          "match": "\\bdo\\b"},
        {"include": "#IfStatement"}]
    },
    "IfStatement": {
      "patterns": [
        { "name": "keyword.controll.statement.if",
          "match": "\\bif\\b"},
        { "name": "keyword.controll.statement.else",
          "match": "\\belse\\b"}]
    },
    "Comment": {
      "name": "comment",
      "patterns": [
        {"include":"#CommentLine"},
        {"include":"#CommentBlock"}]
    },
    "CommentLine": {
      "name": "comment.line.double-slash",
      "match": "(//)( ?TODO:?)?(.*$)",
      "captures" : {
        "2": {"name": "constant.other.todo"}
      }
    },
    "CommentBlock": {
      "name": "comment.block",
      "begin": "(/\\*)( ?TODO:?)?",
      "end": "\\*/",
      "beginCaptures": {
        "1": {"name": "comment.block"},
        "2": {"name": "constant.other.todo"}
      }
    },
    "FunctionDeclaration": {
      "name": "meta.statement.definition.function",
      "begin": "(\\b[a-zA-Z_][a-zA-Z0-9]*\\b)? *(\\bfunc\\b) *(\\b[a-zA-Z_][a-zA-Z0-9]*\\b) *\\(",
      "end": "\\)",
      "patterns": [
        {"include": "#ArgumentDeclaration"}
      ],
      "beginCaptures": {
        "1": {"name": "entity.name.type"},
        "2": {"name": "entity.name.tag"},
        "3": {"name": "entity.name.function.function-id"}
      }
    },
    "ArgumentDeclaration": {
      "name": "meta.function.declaration.argument",
      "match": "([a-z]+) *([a-zA-Z_][a-zA-Z0-9]*)",
      "captures":{
        "1": {"name": "storage.type"},
        "2": {"name": "variable.parameter"}
      }
    },
    "VariableDeclaration": {
      "name": "meta.statement.declaration.variable",
      "match": "(?=^|.*;) *([a-z]+)? *\\b([a-zA-Z_][a-zA-Z0-9]*) *(?=;|$|//|/\\*)",
      "captures":{
        "1":{"name": "storage.type"},
        "2":{"name": "variable"}
      }
    }
  }
}