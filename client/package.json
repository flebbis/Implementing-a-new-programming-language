{
  "name": "mylang-client",
  "description": "language server client for unnamed language",
  "author": "Cole",
  "license": "MIT",
  "version": "0.0.1",
  "publisher": "we :)",
  "repository": {
    "type": "git",
    "url": "https://github.com/MindokRuvaak/LS-experimenting"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.81.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "asm-preview.show",
        "title": "Show Assembly"
      },
      {
        "command": "opt.buttons",
        "title": "optimazation"
      },
      {
        "command": "O0",
        "title": "No optimazation"
      },
      {
        "command": "O1",
        "title": "Basic optimazation"
      },
      {
        "command": "O2",
        "title": "More optimazation"
      },
      {
        "command": "O3",
        "title": "Max optimazation"
      }
    ],

  "submenus":[
    {
      "id": "opt",
      "label": "optimazation",
      "icon": "$(list-selection)"
    }
  ],  

  "menus": {
    "editor/title": [
      {
        "submenu": "opt",
        "when": "true",
        "group": "navigation"
      }
    ],

  "opt": [
    {
      "command": "O0",
      "group": "navigation" 
    },
    {
      "command": "O1",
      "group": "navigation" 
    },
    {
      "command": "O2",
      "group": "navigation" 
    },
    {
      "command": "O3",
      "group": "navigation" 
    }
  ]
}

  }
}
