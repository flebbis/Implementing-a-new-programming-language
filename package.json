{
  "name": "mylang",
  "description": "language server following lsp for this unnamed language",
  "author": "Cole",
  "license": "MIT",
  "version": "0.0.2",
  "publisher": "Cole",
  "repository": {
    "type": "git",
    "url": "https://github.com/flebbis/Implementing-a-new-programming-language/tree/language-server"
  },
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "activationEvents": [],
  "main": "./client/out/extension",
  "contributes": {
    "languages": [
      {
        "id": "mylang",
        "extensions": [
          ".ml"
        ],
        "aliases": [
          "mylang",
          "myLang",
          "MyLang"
        ],
        "configuration": "./language-tools/language-configuration.json"
      },
      { "id": "asm-preview", 
      "aliases": ["Assembly Preview"] 
    }
    ],
    "grammars": [
      {
        "language": "mylang",
        "scopeName": "source.mylang",
        "path": "./language-tools/mylang.tmLanguage.json"
      },
      {
        "language": "asm-preview",
        "scopeName": "source.asm-preview",
        "path": "./language-tools/asm-preview.tmLanguage.json"
      }
      
    ],
    "commands": [
      {
        "command": "assembly-preview.show",
        "title": "Show Assembly"
      },
      {
        "command": "opt.buttons",
        "title": "optimazation"
      },
      {
        "command": "O0",
        "title": "No optimazation"
      },
      {
        "command": "O1",
        "title": "Basic optimazation"
      },
      {
        "command": "O2",
        "title": "More optimazation"
      },
      {
        "command": "O3",
        "title": "Max optimazation"
      },
      {
        "command": "asm-buttons",
        "title": "assemblyOptions"
      },
      {
        "command": "mylang.x86-64",
        "title": "x86-64 (standard)"
      },
      {
        "command": "mylang.arm64",
        "title": "arm64"
      }
    ],

  "submenus":[
    {
      "id": "opt",
      "label": "optimazation",
      "icon": "$(dashboard)"
    },
    {
      "id": "asm",
      "label": "assemblyOptions",
      "icon": "$(chip)"
    }
  ],  

  "menus": {
    "editor/title": [
      {
        "submenu": "opt",
        "when": "true",
        "group": "navigation"
      },
      {
        "submenu": "asm",
        "when": "true",
        "group": "navigation"
      }
    ],
    
  "opt": [
    {
      "command": "O0",
      "group": "navigation" 
    },
    {
      "command": "O1",
      "group": "navigation" 
    },
    {
      "command": "O2",
      "group": "navigation" 
    },
    {
      "command": "O3",
      "group": "navigation" 
    }
  ],
  "asm": [
    {
      "command": "mylang.x86-64",
      "group": "navigation"
    },
    {
      "command": "mylang.arm64",
      "group": "navigation"
    }
  ]
}

  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "devDependencies": {
    "@types/node": "^20.5.7",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}

