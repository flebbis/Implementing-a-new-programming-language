// Function Declarations and Basics
// Void-ish function
func performAction() {
    int i = 0
    i++
}
// Typed Function
bool func isTrue() {
    return true
}
// Function with parameters
int func subtract(int a, int b) {
    return a - b
}
// Inferred return type (if supported)
func compute(int x) {
    return x * x
}
