// Arithmetic and Assignment Tests
int a = 10
int b = 20
int c = 0
// Basic Math
c = a + b
c = b - a
c = a * b
c = b / a
c = 2 ** 3  // Power (funkar inte just nu) (nu funkar det efter jag hittade det här)
// Compound Assignment
a += 5
b -= 5
a *= 2
b /= 2
// Complex Precedence (Multiplication before Addition)
c = 5 + 3 * 2
c = (5 + 3) * 2
// Unary
int x = 1
x++
x--
